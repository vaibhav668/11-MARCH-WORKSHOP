#include <Wire.h>
#include <Adafruit_LiquidCrystal.h>
#include <Keypad.h>
#include <Servo.h>


Adafruit_LiquidCrystal lcd(0);


Servo lockServo;


const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {9, 8, 7, 6};
byte colPins[COLS] = {5, 4, 3, 2};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);


String password = "1234";
String input = "";


int buzzer = 10;

// Security
int attempts = 0;
bool locked = false;

void setup() {
  lcd.begin(16, 2);
  lcd.setBacklight(1);

  pinMode(buzzer, OUTPUT);

  lockServo.attach(11);
  lockServo.write(0); // LOCK

  lcd.print("Door Locked");
  delay(2000);
  lcd.clear();
  lcd.print("Enter Password:");
}

void loop() {

  if (locked) {
    lcd.setCursor(0, 0);
    lcd.print("SYSTEM LOCKED ");
    lcd.setCursor(0, 1);
    lcd.print("RESET REQUIRED");

    tone(buzzer, 1000); // continuous beep
    delay(200);

    return; // stop everything
  }

  char key = keypad.getKey();

  if (key) {
    tone(buzzer, 1000);
    delay(100);
    noTone(buzzer);

   
    if (key == '*') {
      input = "";
      lcd.clear();
      lcd.print("Enter Password:");
      return;
    }

    input += key;

    lcd.setCursor(0, 1);
    for (int i = 0; i < input.length(); i++) {
      lcd.print("*");
    }

    if (input.length() == 4) {
      lcd.clear();

      if (input == password) {

        lcd.print("Access Granted");

       
        lockServo.write(90);

        tone(buzzer, 1500);
        delay(500);
        noTone(buzzer);

        delay(3000);

       
        lockServo.write(0);

        attempts = 0; 
        lcd.clear();
        lcd.print("Door Locked");

      } else {

        attempts++;

        lcd.print("Wrong Password");
        lcd.setCursor(0, 1);
        lcd.print("Attempts: ");
        lcd.print(attempts);

        
        for (int i = 0; i < 3; i++) {
          tone(buzzer, 500);
          delay(200);
          noTone(buzzer);
          delay(200);
        }

      
        if (attempts >= 3) {
          locked = true;
          lcd.clear();
          lcd.print("SYSTEM LOCKED!");
        }
      }

      delay(2000);

      input = "";
      lcd.clear();
      lcd.print("Enter Password:");
    }
  }
}
